# ============================================================
# Configuração do BACKEND — Plataforma de Agentes IA
# Copie este arquivo para ".env" e preencha os valores.
# ============================================================

# Chave da API da OpenAI (necessária para respostas reais da IA).
# Sem ela, a plataforma roda em "modo demonstração" (tudo funciona,
# mas o agente responde com uma mensagem simulada).
OPENAI_API_KEY=

# Modelo de linguagem usado pelos agentes.
OPENAI_MODEL=gpt-4o-mini

# Modelo de embeddings usado pelas bases de conhecimento (RAG).
EMBEDDING_MODEL=text-embedding-3-small

# Segredo usado para assinar os tokens JWT de login.
# TROQUE por um valor aleatório e secreto em produção.
JWT_SECRET=troque-este-segredo-em-producao

# Banco de dados (opcional). Padrão: SQLite local (sqlite:///./app.db).
# Para PostgreSQL, use algo como: postgresql://usuario:senha@host:5432/banco
# DATABASE_URL=

# Diretório de persistência de vetores (opcional).
CHROMA_DIR=./chroma_data
CHROMA_PERSISTENT=0

# ============================================================
# Login social (OAuth2) — opcional
# ============================================================
# URLs públicas usadas no fluxo OAuth (ajuste em produção).
OAUTH_BACKEND_URL=http://127.0.0.1:8000
FRONTEND_URL=http://localhost:3000

# Google  -> https://console.cloud.google.com/apis/credentials
#   Redirect URI autorizada: {OAUTH_BACKEND_URL}/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Facebook -> https://developers.facebook.com/apps
#   Redirect URI: {OAUTH_BACKEND_URL}/auth/facebook/callback
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# GitHub  -> https://github.com/settings/developers (OAuth Apps)
#   Authorization callback URL: {OAUTH_BACKEND_URL}/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ============================================================
# Admin e pagamentos (opcional)
# ============================================================
# E-mail que recebe as "solicitações de integração" no painel admin.
ADMIN_EMAIL=andre.rodrigues1022@gmail.com

# Mercado Pago (checkout dos planos) -> https://www.mercadopago.com.br/developers/panel
# Cole o "Access Token" de produção (ou de teste) aqui.
MERCADOPAGO_ACCESS_TOKEN=

# WhatsApp: NÃO precisa de variável aqui. Cada usuário conecta o próprio número
# em Integrações (phone_number_id + access_token do Meta Cloud API).

# ============================================================
# E-mail (verificação de conta + redefinição de senha)
# ============================================================
# Sem SMTP configurado, o sistema NÃO envia e-mail de verdade: ele apenas
# imprime o link no log do servidor (útil para testar localmente).
# Para enviar e-mails reais, configure um SMTP. Ex. Gmail (use uma
# "Senha de app", não a senha normal): https://myaccount.google.com/apppasswords
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
# IMPORTANTE: em produção, defina FRONTEND_URL (acima) com a URL pública do
# frontend (ex.: https://...vercel.app) para que os links de e-mail funcionem.
